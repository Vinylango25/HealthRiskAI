# =============================================================================
# HealthRisk AI — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# =============================================================================

# ── PhysioNet / MIMIC-IV ──────────────────────────────────────────────────────
PHYSIONET_USERNAME=your_username
PHYSIONET_PASSWORD=your_password

# ── WHO Global Health Observatory ─────────────────────────────────────────────
WHO_GHO_BASE_URL=https://ghoapi.azureedge.net/api

# ── ClinicalTrials.gov ────────────────────────────────────────────────────────
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2

# ── openFDA FAERS ─────────────────────────────────────────────────────────────
OPENFDA_API_KEY=your_openfda_api_key
OPENFDA_BASE_URL=https://api.fda.gov/drug

# ── CDC WONDER ────────────────────────────────────────────────────────────────
CDC_WONDER_BASE_URL=https://wonder.cdc.gov

# ── CMS (Centers for Medicare & Medicaid Services) ────────────────────────────
CMS_BASE_URL=https://data.cms.gov/provider-data/api/1/datastore/sql

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
SEC_EDGAR_BASE_URL=https://data.sec.gov
SEC_EDGAR_USER_AGENT=HealthRisk-AI/1.0 contact@healthrisk.ai

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://healthrisk:password@localhost:5432/healthrisk
POSTGRES_PASSWORD=changeme

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=healthrisk-ai

# ── Weights & Biases ──────────────────────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=healthrisk-ai
WANDB_ENTITY=your_team

# ── DVC remote storage ────────────────────────────────────────────────────────
DVC_REMOTE_URL=s3://your-bucket/healthrisk-ai-data

# ── Cron protection ───────────────────────────────────────────────────────────
CRON_SECRET=replace_with_long_random_secret

# ── Application settings ──────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# ── Rate limiting ─────────────────────────────────────────────────────────────
API_RATE_LIMIT_PER_MINUTE=60
DATA_FETCH_CONCURRENCY=5
REQUEST_TIMEOUT_SECONDS=30
