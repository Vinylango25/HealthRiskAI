# =============================================================================
# HealthRisk AI — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
#
# ── Render deployment notes ───────────────────────────────────────────────────
# On Render, DO NOT set these via .env — use the Render dashboard instead:
#   Dashboard → healthrisk-api → Environment
#
# Variables marked [RENDER: auto] are injected automatically by Render.
# Variables marked [RENDER: set in dashboard] must be added manually.
# Variables marked [RENDER: pre-configured] are set in render.yaml already.
# =============================================================================

# ── PhysioNet / MIMIC-IV ──────────────────────────────────────────────────────
# [RENDER: set in dashboard]
PHYSIONET_USERNAME=your_username
PHYSIONET_PASSWORD=your_password

# ── WHO Global Health Observatory ─────────────────────────────────────────────
# [RENDER: pre-configured in render.yaml]
WHO_GHO_BASE_URL=https://ghoapi.azureedge.net/api

# ── ClinicalTrials.gov ────────────────────────────────────────────────────────
# [RENDER: pre-configured in render.yaml]
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2

# ── openFDA FAERS ─────────────────────────────────────────────────────────────
# [RENDER: set in dashboard]
OPENFDA_API_KEY=your_openfda_api_key
# [RENDER: pre-configured in render.yaml]
OPENFDA_BASE_URL=https://api.fda.gov/drug

# ── CDC WONDER ────────────────────────────────────────────────────────────────
# [RENDER: pre-configured in render.yaml]
CDC_WONDER_BASE_URL=https://wonder.cdc.gov

# ── CMS (Centers for Medicare & Medicaid Services) ────────────────────────────
# [RENDER: pre-configured in render.yaml]
CMS_BASE_URL=https://data.cms.gov/provider-data/api/1/datastore/sql

# ── SEC EDGAR ─────────────────────────────────────────────────────────────────
# [RENDER: pre-configured in render.yaml]
SEC_EDGAR_BASE_URL=https://data.sec.gov
SEC_EDGAR_USER_AGENT=HealthRisk-AI/1.0 contact@healthrisk.ai

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# [RENDER: set in dashboard]
GEMINI_API_KEY=your_gemini_api_key

# ── Database ──────────────────────────────────────────────────────────────────
# [RENDER: auto] — Render injects DATABASE_URL automatically from the linked
# managed Postgres instance defined in render.yaml. You do not need to set
# this manually on Render.
#
# For local development, use the docker-compose Postgres instance:
DATABASE_URL=postgresql://healthrisk:password@localhost:5432/healthrisk
POSTGRES_PASSWORD=changeme

# ── MLflow ────────────────────────────────────────────────────────────────────
# [RENDER: pre-configured in render.yaml] falls back to local ./mlruns
# For production persistence, point at S3 or a dedicated MLflow service.
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=healthrisk-ai

# ── Weights & Biases ──────────────────────────────────────────────────────────
# [RENDER: set in dashboard]
WANDB_API_KEY=your_wandb_api_key
# [RENDER: pre-configured in render.yaml]
WANDB_PROJECT=healthrisk-ai
# [RENDER: set in dashboard]
WANDB_ENTITY=your_team

# ── DVC remote storage ────────────────────────────────────────────────────────
# Not used on Render directly — configure DVC remotes separately (e.g. S3).
DVC_REMOTE_URL=s3://your-bucket/healthrisk-ai-data

# ── Cron protection ───────────────────────────────────────────────────────────
# [RENDER: set in dashboard] — generate with: openssl rand -hex 32
CRON_SECRET=replace_with_long_random_secret

# ── Application settings ──────────────────────────────────────────────────────
# [RENDER: pre-configured in render.yaml]
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# ── Rate limiting ─────────────────────────────────────────────────────────────
# [RENDER: pre-configured in render.yaml]
API_RATE_LIMIT_PER_MINUTE=60
DATA_FETCH_CONCURRENCY=5
REQUEST_TIMEOUT_SECONDS=30
